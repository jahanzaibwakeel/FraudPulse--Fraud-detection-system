# Copy this file to .env on the Oracle VM.
# Do not commit your real .env file or private SSH keys.

WEB_DOMAIN=fraudpulse-demo.example.com
API_DOMAIN=fraudpulse-api.example.com

POSTGRES_DB=fraudpulse
POSTGRES_USER=fraudpulse
POSTGRES_PASSWORD=change-this-to-a-long-random-password
DATABASE_URL=postgres://fraudpulse:change-this-to-a-long-random-password@postgres:5432/fraudpulse

VALKEY_URL=redis://valkey:6379
API_PORT=4000

NEXT_PUBLIC_API_URL=https://fraudpulse-api.example.com
NEXT_PUBLIC_WS_URL=https://fraudpulse-api.example.com

SIMULATOR_TPS=2
LOG_LEVEL=info
AUTH_ENABLED=true

# Format:
# token:actor:role,token:actor:role
API_TOKENS=replace-viewer-token:viewer.demo:viewer,replace-analyst-token:casey.ops:analyst,replace-admin-token:lead.ops:admin,replace-service-token:pipeline.service:service
API_SERVICE_TOKEN=replace-service-token
NEXT_PUBLIC_API_TOKEN=replace-admin-token

ALLOWED_ORIGINS=https://fraudpulse-demo.example.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=900
SESSION_TTL_MS=28800000
AUTH_FAILURE_WINDOW_MS=300000
AUTH_FAILURE_MAX_ATTEMPTS=8
AUTH_LOCKOUT_MS=600000

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-this-grafana-password
